{
  "expo": {
    "name": "Fime",
    "slug": "fime",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/fime_logo.png",
    "scheme": "fime",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shauritanga.fime"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#090D16",
        "foregroundImage": "./assets/images/android-icon-fime-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.shauritanga.fime"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/fime_logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/fime_logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#F7F2EA"
        }
      ],
      "expo-notifications",
      "expo-sqlite",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec695d3e-85cc-4ed6-8d38-1d0bafd48062"
      }
    },
    "owner": "shauritanga"
  }
}
